{
  "name": "C",
  "file_extensions": ["c", "h"],
  "rules": [
    { "scope": "comment.line", "pattern": "//.*$" },
    { "scope": "comment.block", "begin": "/\\*", "end": "\\*/" },

    { "scope": "string.double", "begin": "\"", "end": "\"" },
    { "scope": "string.single", "begin": "'", "end": "'" },

    { "scope": "keyword.meta", "pattern": "\\b(sizeof|_Alignof|_Generic|_Static_assert|_Thread_local|_Atomic|_Noreturn)\\b" },

    { "scope": "keyword.control", "pattern": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|goto)\\b" },

    { "scope": "keyword.declaration", "pattern": "\\b(typedef|struct|union|enum|auto|register|static|extern)\\b" },

    { "scope": "storage.modifier", "pattern": "\\b(const|volatile|restrict|inline|signed|unsigned|short|long)\\b" },

    { "scope": "keyword.module", "pattern": "#\\s*(include|define|undef|if|ifdef|ifndef|elif|else|endif|error|pragma|line)\\b" },

    { "scope": "modifier.annotation", "pattern": "#[a-zA-Z_][a-zA-Z0-9_]*" },

    { "scope": "keyword.memory", "pattern": "\\b(sizeof)\\b" },

    { "scope": "keyword.reserved", "pattern": "\\b(_Bool|_Complex|_Imaginary)\\b" },

    { "scope": "variable.language", "pattern": "\\b(__func__)\\b" },

    { "scope": "constant.language", "pattern": "\\b(NULL|true|false)\\b" },

    { "scope": "storage.type", "pattern": "\\b(void|char|int|float|double|_Bool)\\b" },

    { "scope": "constant.numeric", "pattern": "\\b0[xX][0-9a-fA-F_]+\\b" },
    { "scope": "constant.numeric", "pattern": "\\b0[bB][01_]+\\b" },
    {
      "scope": "constant.numeric",
      "pattern": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9_]+)?([uU]?[lL]{0,2}|[fF]|[lL])?\\b"
    },

    { "scope": "entity.name.type", "pattern": "\\b[A-Z][a-zA-Z0-9_]*\\b" }
  ]
}