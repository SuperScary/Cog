{
    "name": "Rust",
    "file_extensions": ["rs"],
    "rules": [
      { "scope": "comment.line", "pattern": "//.*$" },
      { "scope": "comment.block", "begin": "/\\*", "end": "\\*/" },
  
      { "scope": "string.double", "begin": "\"", "end": "\"" },
      { "scope": "string.single", "begin": "'", "end": "'" },
  
      { "scope": "keyword.meta", "pattern": "\\b(as|dyn|where|crate|super|self|Self)\\b" },
  
      { "scope": "keyword.control", "pattern": "\\b(if|else|for|while|loop|match|break|continue|return|in)\\b" },
  
      { "scope": "keyword.declaration", "pattern": "\\b(fn|struct|enum|union|trait|impl|type|mod|const|static|let)\\b" },
  
      { "scope": "storage.modifier", "pattern": "\\b(pub|unsafe|async|await|move|mut|ref|extern|default|auto)\\b" },
  
      { "scope": "keyword.module", "pattern": "\\b(mod|use|crate|super|self|pub)\\b" },
  
      { "scope": "keyword.memory", "pattern": "\\b(box)\\b" },
  
      { "scope": "keyword.reserved", "pattern": "\\b(abstract|become|do|final|macro|override|priv|try|typeof|unsized|virtual|yield)\\b" },
  
      { "scope": "variable.language", "pattern": "\\b(self|Self)\\b" },
  
      { "scope": "constant.language", "pattern": "\\b(true|false)\\b" },
  
      { "scope": "storage.type", "pattern": "\\b(u8|u16|u32|u64|u128|usize|i8|i16|i32|i64|i128|isize|f32|f64|bool|char|str)\\b" },
  
      { "scope": "constant.numeric", "pattern": "\\b0[xX][0-9a-fA-F_]+\\b" },
      { "scope": "constant.numeric", "pattern": "\\b0[bB][01_]+\\b" },
      { "scope": "constant.numeric", "pattern": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9_]+)?(u8|u16|u32|u64|u128|usize|i8|i16|i32|i64|i128|isize|f32|f64)?\\b" },
  
      { "scope": "entity.name.type", "pattern": "\\b[A-Z][a-zA-Z0-9_]*\\b" },

      { "scope": "modifier.annotation", "pattern": "\\b#[a-zA-Z0-9_]+\\b" }
    ]
  }